# BotFather -> /newbot
TELEGRAM_TOKEN=123456:ABC-xxxxxxxxxxxxxxxxxxxx

# Il tuo user id: scrivi a @userinfobot su Telegram
TELEGRAM_OWNER_ID=123456789

# Path binario claude (Windows: C:\Users\TU\AppData\Roaming\npm\claude.cmd)
CLAUDE_BIN=claude

# Modello: opus | sonnet | (vuoto = default)
JARVIS_MODEL=

JARVIS_MAX_TURNS=40

# Workspace: cartelle reali sul tuo PC
WS_AURA=C:\Progetti\aura-ibiza
WS_TRADING=C:\Progetti\tradeflow-ai
WS_ISABELA=C:\Progetti\isabela
WS_VINO=C:\Progetti\vinitalimport

# Turso DB "jarvis" (Vercel Storage / turso.tech) — abilita la coda web
# (core/web_bridge.py) e il second brain (core/brain.py). Se vuoti, entrambi
# restano disattivati e JARVIS funziona solo via Telegram senza memoria a lungo termine.
TURSO_JARVIS_DB_URL=libsql://jarvis-xxxxx.turso.io
TURSO_JARVIS_AUTH_TOKEN=
