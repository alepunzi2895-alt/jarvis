# BotFather -> /newbot
TELEGRAM_TOKEN=123456:ABC-xxxxxxxxxxxxxxxxxxxx

# Il tuo user id: scrivi a @userinfobot su Telegram
TELEGRAM_OWNER_ID=123456789

# Path binario claude (Windows: C:\Users\TU\AppData\Roaming\npm\claude.cmd)
CLAUDE_BIN=claude

# Modello: opus | sonnet | (vuoto = default)
JARVIS_MODEL=

JARVIS_MAX_TURNS=40

# Workspace: cartelle reali sul tuo PC
WS_AURA=C:\Progetti\aura-ibiza
WS_TRADING=C:\Progetti\tradeflow-ai
WS_ISABELA=C:\Progetti\isabela
WS_VINO=C:\Progetti\vinitalimport

# Turso DB "jarvis" (Vercel Storage / turso.tech) — abilita la coda web
# (core/web_bridge.py) e il second brain (core/brain.py). Se vuoti, entrambi
# restano disattivati e JARVIS funziona solo via Telegram senza memoria a lungo termine.
TURSO_JARVIS_DB_URL=libsql://jarvis-xxxxx.turso.io
TURSO_JARVIS_AUTH_TOKEN=

# Vault Obsidian (cartella con .obsidian/ dentro). Se assente/non trovato,
# /note e /search restano disabilitati ma il resto di JARVIS funziona lo stesso.
JARVIS_VAULT_PATH=C:\Progetti\jarvis\jarvis

# Directory extra (oltre a JARVIS_HOME) autorizzate per SystemExecutor
# (/run, read_file, write_file, list_dir) — separate da virgola.
JARVIS_ALLOWED_DIRS=C:\Progetti\tradeflow-ai,C:\Progetti\whitesoulibiza

# Daemon vocale nativo (blocco c2, start_voice.bat). Valori di default già
# sensati: lascia vuoto per usarli.
JARVIS_WAKE_WORD_MODEL=hey_jarvis
JARVIS_WAKE_WORD_THRESHOLD=0.5
JARVIS_WHISPER_MODEL=small
JARVIS_TTS_VOICE=it-IT-GiuseppeMultilingualNeural
JARVIS_SILENCE_RMS=300

# Sottostringa (case-insensitive) del nome del microfono da usare — utile se
# Windows cambia il device di default quando colleghi/scolleghi una cuffia.
# Vuoto = usa il default di sistema.
JARVIS_MIC_DEVICE=

# Hotkey globale per avviare l'ascolto senza dover dire la wake word (in
# aggiunta, non in sostituzione — utile se "hey jarvis" non riconosce la tua
# voce). Sintassi della libreria "keyboard": es. ctrl+alt+j, ctrl+shift+space.
JARVIS_HOTKEY=ctrl+alt+j

# Sottostringa (case-insensitive) del nome dell'altoparlante/cuffia da usare
# per la voce di JARVIS — stesso problema di JARVIS_MIC_DEVICE ma in uscita.
# Vuoto = usa il default di sistema.
JARVIS_SPEAKER_DEVICE=

# Meteo (core/weather.py), iniettato nel prompt come la data/ora — nessuna API
# key richiesta (Open-Meteo + ip-api.com sono gratuiti). Tutto vuoto = posizione
# dedotta dall'IP del PC (utile se ti sposti spesso, ma impreciso dietro VPN
# aziendale). Per fissare una posizione esplicita usa LAT/LON oppure CITY:
JARVIS_WEATHER_LAT=
JARVIS_WEATHER_LON=
JARVIS_WEATHER_CITY=

# Canale testo/Telegram/dashboard (core/claude_bridge.py): usa il flag CLI
# --bare per saltare l'overhead di Claude Code non pertinente a JARVIS (hook,
# LSP, plugin sync, auto-memory, CLAUDE.md auto-discovery). Costo per chiamata
# nettamente piu' basso, ma l'autenticazione passa da abbonamento/OAuth a
# pagamento a consumo su ANTHROPIC_API_KEY per QUESTO canale (prima solo la
# voce ci passava). Metti a 0 per tornare al comportamento precedente.
JARVIS_CLI_BARE=1
